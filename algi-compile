#!/bin/bash
# Script de compilation simplifié pour ALGI
# Usage: ./algi-compile [c|asm] fichier.algi

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Couleurs
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

error() { echo -e "${RED}❌ $*${NC}" >&2; }
success() { echo -e "${GREEN}✅ $*${NC}"; }
info() { echo -e "${BLUE}ℹ️ $*${NC}"; }

# Créer les répertoires
mkdir -p output

# Fonction de compilation
compile() {
    local mode="$1"
    local input="$2"
    
    if [ ! -f "$input" ]; then
        error "Fichier non trouvé: $input"
        return 1
    fi
    
    info "Compilation de $input ($mode)..."
    
    # Choisir le mode
    case "$mode" in
        c|--c|-c)
            ./algi -c "$input"
            ;;
        asm|--asm|-a)
            ./algi -a "$input"
            ;;
        *)
            error "Mode inconnu: $mode"
            return 1
            ;;
    esac
    
    local base=$(basename "$input" .algi)
    
    # Déplacer les fichiers générés
    if [ "$mode" = "c" ] || [ "$mode" = "-c" ] || [ "$mode" = "--c" ]; then
        if [ -f "${base}.c" ]; then
            mv "${base}.c" "output/${base}.c"
            info "Fichier C: output/${base}.c"
            
            # Compiler l'exécutable
            info "Compilation de output/${base}.c..."
            gcc -Wall -I./src -o "output/${base}" "output/${base}.c" src/runtime.c -lm
            success "Exécutable: output/${base}"
        else
            # Chercher dans examples/
            if [ -f "examples/${base}.c" ]; then
                mv "examples/${base}.c" "output/${base}.c"
                info "Fichier C: output/${base}.c"
                gcc -Wall -I./src -o "output/${base}" "output/${base}.c" src/runtime.c -lm
                success "Exécutable: output/${base}"
            fi
        fi
    fi
    
    if [ "$mode" = "asm" ] || [ "$mode" = "-a" ] || [ "$mode" = "--asm" ]; then
        if [ -f "${base}.asm" ]; then
            mv "${base}.asm" "output/${base}.asm"
            info "Fichier ASM: output/${base}.asm"
            
            # Assembler
            info "Assemblage de output/${base}.asm..."
            nasm -f elf32 -o "output/${base}.o" "output/${base}.asm"
            gcc -m32 -o "output/${base}_asm" "output/${base}.o" -lc
            success "Exécutable: output/${base}_asm"
        else
            if [ -f "examples/${base}.asm" ]; then
                mv "examples/${base}.asm" "output/${base}.asm"
                info "Fichier ASM: output/${base}.asm"
                nasm -f elf32 -o "output/${base}.o" "output/${base}.asm"
                gcc -m32 -o "output/${base}_asm" "output/${base}.o" -lc
                success "Exécutable: output/${base}_asm"
            fi
        fi
    fi
    
    success "Compilation terminée"
}

# Exécuter le programme
run() {
    local base="$1"
    local exe="output/${base}"
    if [ ! -f "$exe" ]; then
        exe="output/${base}_asm"
    fi
    if [ ! -f "$exe" ]; then
        error "Exécutable non trouvé: $exe"
        return 1
    fi
    info "Exécution de $exe..."
    echo "------------------------"
    "$exe"
    echo "------------------------"
    success "Terminé"
}

# Aide
show_help() {
    cat << EOF
ALGI Compiler - Script simplifié
Usage: $0 [OPTIONS] FICHIER.algi

Options:
  c, -c, --c     Compiler vers C
  a, -a, --asm   Compiler vers Assembleur
  r, -r, --run   Exécuter le programme compilé
  clean          Nettoyer les fichiers générés
  help           Afficher cette aide

Exemples:
  $0 c test.algi     # Compiler test.algi vers C
  $0 a test.algi     # Compiler test.algi vers Assembleur
  $0 r test          # Exécuter le programme test
  $0 clean           # Nettoyer

EOF
}

# Clean
clean() {
    info "Nettoyage..."
    rm -rf output
    rm -f examples/*.{c,o,asm}
    mkdir -p output
    success "Nettoyage terminé"
}

# Main
main() {
    if [ $# -lt 1 ]; then
        show_help
        exit 1
    fi
    
    case "$1" in
        c|-c|--c)
            if [ $# -lt 2 ]; then
                error "Fichier source requis"
                exit 1
            fi
            compile c "$2"
            ;;
        a|-a|--asm)
            if [ $# -lt 2 ]; then
                error "Fichier source requis"
                exit 1
            fi
            compile asm "$2"
            ;;
        r|-r|--run)
            if [ $# -lt 2 ]; then
                error "Nom du programme requis"
                exit 1
            fi
            run "$2"
            ;;
        clean)
            clean
            ;;
        help|-h|--help)
            show_help
            ;;
        *)
            error "Option inconnue: $1"
            show_help
            exit 1
            ;;
    esac
}

main "$@"